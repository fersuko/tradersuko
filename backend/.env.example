# ── Database ──
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=hermes_trading
DB_USER=your_user
DB_PASS=your_password

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_DIST=/path/to/tradersuko/dist

# ── Binance API Keys (REAL) ──
EXCHANGE_API_KEY=your_binance_api_key
EXCHANGE_SECRET=your_binance_secret

# ── Binance API Keys (DEMO/testnet) ──
EXCHANGE_API_KEY_DEMO=your_demo_key
EXCHANGE_SECRET_DEMO=your_demo_secret

# ── MEXC (secondary) ──
MEXC_API_KEY=your_mexc_key
MEXC_SECRET_KEY=your_mexc_secret
